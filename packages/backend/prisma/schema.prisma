generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

enum RolePreference {
  STAKER
  LP
}

enum Direction {
  ABOVE
  BELOW
}

model User {
  walletAddress             String          @id
  rolePreference            RolePreference  @default(STAKER)
  globalAccumulatorSnapshot Float           @default(0)
  totalLiquidityProvided    Float           @default(0)
  positions                 Position[]
}

model Market {
  marketId          String     @id
  title             String
  category          String
  currentMu         Float
  currentSigma      Float
  totalLiquidity    Float      @default(0)
  globalAccumulator Float      @default(0)
  minVarianceBound  Float
  ammAddress        String     @default("")
  routerAddress     String     @default("")
  lpTokenAddress    String     @default("")
  isResolved        Boolean    @default(false)
  winningTokenId    String?
  positions         Position[]
}

model Position {
  positionId   String    @id
  userAddress  String
  marketId     String
  targetValueX Float
  direction    Direction
  tokensMinted Float
  stakeAmount  Float

  user   User   @relation(fields: [userAddress], references: [walletAddress])
  market Market @relation(fields: [marketId], references: [marketId])
}
